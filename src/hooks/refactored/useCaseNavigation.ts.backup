import { useCallback } from "react";
import type { Phase, PatientCase } from "@/lib/types";

interface UseCaseNavigationReturn {
  phase: Phase;
  setPhase: React.Dispatch<React.SetStateAction<Phase>>;
  goToComplaints: () => void;
  goToDynamic: () => Promise<void>;
  goBack: (patientCase: PatientCase, stepStack: StepRecord[], setStepStack: React.Dispatch<React.SetStateAction<StepRecord[]>>, setPatientCase: React.Dispatch<React.SetStateAction<PatientCase>>, setPhase: React.Dispatch<React.SetStateAction<Phase>>, fetchNextStep: (caseData: PatientCase, stack: StepRecord[]) => Promise<void>, refreshLocalInsight: (caseData: PatientCase) => void) => Promise<void>;
}

type Mode = "clinical" | "classic";
type Phase = "demographics" | "complaints" | "dynamic" | "results" | "presentation";

interface StepRecord {
  fieldKey: string;
  category: string;
}

export function useCaseNavigation(mode: Mode) {
  const [phase, setPhase] = useState<Phase>("demographics");
  const complaintPool = [
    "Fever", "Cough", "Chest pain", "Abdominal pain", "Headache",
    "Shortness of breath", "Nausea / vomiting", "Rash", "Sore throat", "Dizziness",
  ];

  const goToComplaints = useCallback(() => {
    // This would normally check patientCase validity, but we're passing that logic to the caller
    setPhase("complaints");
  }, []);

  const goToDynamic = useCallback(async (
    setPatientCase: React.Dispatch<React.SetStateAction<PatientCase>>,
    patientCase: PatientCase,
    setStepStack: React.Dispatch<React.SetStateAction<StepRecord[]>>,
    refreshLocalInsight: (caseData: PatientCase) => void,
    fetchNextStep: (caseData: PatientCase, stack: StepRecord[]) => Promise<void>
  ) => {
    if (patientCase.chiefComplaints.length === 0) return;
    setPhase("dynamic");
    setStepStack([]);
    await fetchNextStep(patientCase, []);
    refreshLocalInsight(patientCase);
  }, []);

  const goBack = useCallback(async (
    phase: Phase,
    patientCase: PatientCase,
    stepStack: StepRecord[],
    setStepStack: React.Dispatch<React.SetStateAction<StepRecord[]>>,
    setPatientCase: React.Dispatch<React.SetStateAction<PatientCase>>,
    setPhase: React.Dispatch<React.SetStateAction<Phase>>,
    fetchNextStep: (caseData: PatientCase, stack: StepRecord[]) => Promise<void>,
    refreshLocalInsight: (caseData: PatientCase) => void
  ) => {
    if (phase === "complaints") {
      setPhase("demographics");
      return;
    }
    if (phase === "dynamic" && stepStack.length === 0) {
      setPhase("complaints");
      return;
    }
    if (phase === "dynamic" && stepStack.length > 0) {
      const last = stepStack[stepStack.length - 1];
      const updated = { ...patientCase };

      if (last.category === "exam") {
        const { [last.fieldKey]: _unused, ...rest } = updated.exam;
        void _unused;
        updated.exam = rest;
      } else if (last.category === "investigations") {
        updated.investigations = [];
      } else {
        const { [last.fieldKey]: _unused, ...rest } = updated.history;
        void _unused;
        updated.history = rest;
      }

      const newStack = stepStack.slice(0, -1);
      setStepStack(newStack);
      setPatientCase(updated);
      await fetchNextStep(updated, newStack);
      refreshLocalInsight(updated);
    }
  }, []);

  return {
    phase,
    setPhase,
    goToComplaints,
    goToDynamic,
    goBack
  };
}